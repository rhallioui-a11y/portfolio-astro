---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rym Hallioui | Portfolio</title>
    <meta
      name="description"
      content="Portfolio of Rym Hallioui, Software Engineering Student at ESISA."
    />

    <style>
      :root {
        --bg: #fff8fc;
        --bg-soft: #fff1f7;
        --card: rgba(255, 255, 255, 0.82);
        --text: #24141b;
        --muted: #6f5460;
        --primary: #ff5fa2;
        --primary-dark: #de3f86;
        --primary-soft: #ffd4e7;
        --secondary: #ffffff;
        --border: rgba(255, 95, 162, 0.14);
        --shadow: 0 20px 45px rgba(255, 95, 162, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(255, 205, 228, 0.75), transparent 28%),
          radial-gradient(circle at top right, rgba(255, 228, 239, 0.9), transparent 24%),
          linear-gradient(180deg, #fff9fc 0%, #fff3f8 45%, #fff8fc 100%);
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      .container {
        width: min(1140px, calc(100% - 32px));
        margin: 0 auto;
      }

      .navbar {
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(14px);
        background: rgba(255, 248, 252, 0.78);
        border-bottom: 1px solid rgba(255, 95, 162, 0.08);
      }

      .nav-inner {
        width: min(1140px, calc(100% - 32px));
        margin: 0 auto;
        padding: 18px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--primary-dark);
      }

      .nav-links {
        display: flex;
        gap: 22px;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--muted);
        font-weight: 700;
        transition: 0.25s ease;
      }

      .nav-links a:hover {
        color: var(--primary-dark);
      }

      .hero {
        padding: 74px 0 48px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 28px;
        align-items: center;
      }

      .hero-content,
      .hero-photo-box,
      .about-card,
      .skill-card,
      .education-card,
      .project-card,
      .contact-card {
        background: var(--card);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        border-radius: 28px;
      }

      .hero-content {
        padding: 38px 32px;
      }

      .availability {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 10px 16px;
        color: var(--primary-dark);
        font-weight: 700;
        margin-bottom: 22px;
      }

      .availability-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #35c36d;
        box-shadow: 0 0 0 8px rgba(53, 195, 109, 0.12);
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.5rem);
        line-height: 1.02;
      }

      .hero-role {
        margin: 16px 0 0;
        font-size: 1.28rem;
        font-weight: 800;
        color: var(--primary-dark);
      }

      .hero-school {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 1.05rem;
      }

      .hero-description {
        margin: 18px 0 0;
        color: var(--muted);
        max-width: 680px;
        line-height: 1.75;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 28px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 14px 22px;
        border-radius: 999px;
        font-weight: 700;
        transition: 0.25s ease;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--primary), #ff92be);
        color: white;
        box-shadow: 0 14px 28px rgba(255, 95, 162, 0.22);
      }

      .btn-primary:hover,
      .btn-secondary:hover {
        transform: translateY(-2px);
      }

      .btn-secondary {
        background: white;
        color: var(--primary-dark);
        border: 1px solid var(--border);
      }

      .hero-socials {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .social-pill {
        background: rgba(255,255,255,0.92);
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 12px 16px;
        border-radius: 999px;
        font-weight: 700;
        transition: 0.25s ease;
      }

      .social-pill:hover {
        color: var(--primary-dark);
        background: var(--bg-soft);
        transform: translateY(-2px);
      }

      .hero-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-top: 28px;
      }

      .stat-card {
        background: rgba(255,255,255,0.92);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 18px;
        text-align: center;
      }

      .stat-value {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--primary-dark);
      }

      .stat-label {
        margin-top: 6px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .hero-photo-box {
        padding: 28px;
        text-align: center;
      }

      .profile-photo {
        width: 290px;
        height: 290px;
        object-fit: cover;
        object-position: center top;
        border-radius: 50%;
        padding: 7px;
        background: linear-gradient(135deg, #ffc7e3, #ff5fa2, #ffd7e8);
        box-shadow:
          0 30px 60px rgba(255, 95, 162, 0.25),
          0 10px 24px rgba(0, 0, 0, 0.12);
        transition: transform 0.35s ease;
      }

      .profile-photo:hover {
        transform: scale(1.03);
      }

      .photo-caption {
        margin-top: 18px;
        color: var(--muted);
        font-size: 0.98rem;
      }

      section {
        padding: 36px 0;
      }

      .section-title {
        margin: 0 0 16px;
        font-size: 2rem;
        color: var(--primary-dark);
      }

      .section-subtitle {
        margin: 0 0 26px;
        color: var(--muted);
        max-width: 760px;
        line-height: 1.75;
      }

      .about-grid,
      .skills-grid,
      .education-grid,
      .projects-grid,
      .contact-grid {
        display: grid;
        gap: 20px;
      }

      .about-grid,
      .education-grid,
      .projects-grid,
      .contact-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .skills-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .about-card,
      .skill-card,
      .education-card,
      .project-card,
      .contact-card {
        padding: 24px;
      }

      .about-number {
        color: var(--primary-dark);
        font-weight: 800;
        margin-bottom: 10px;
      }

      .about-card p,
      .skill-card p,
      .education-card p,
      .project-card p,
      .contact-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.75;
      }

      .skill-card h3,
      .education-card h3,
      .project-card h3,
      .contact-card h3 {
        margin: 0 0 14px;
        font-size: 1.2rem;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
      }

      .tag {
        padding: 9px 12px;
        border-radius: 999px;
        background: var(--bg-soft);
        color: var(--primary-dark);
        border: 1px solid rgba(255, 95, 162, 0.12);
        font-size: 0.92rem;
        font-weight: 700;
      }

      .education-badge {
        display: inline-block;
        margin-bottom: 12px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--bg-soft);
        color: var(--primary-dark);
        font-weight: 700;
        font-size: 0.9rem;
      }

      .project-card {
        position: relative;
        overflow: hidden;
      }

      .project-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 5px;
        background: linear-gradient(90deg, #ffc7e3, #ff5fa2, #ffd7e8);
      }

      .project-link,
      .contact-link {
        display: inline-block;
        margin-top: 16px;
        color: var(--primary-dark);
        font-weight: 700;
      }

      .project-link:hover,
      .contact-link:hover {
        text-decoration: underline;
      }

      .footer {
        margin-top: 26px;
        border-top: 1px solid rgba(255, 95, 162, 0.12);
        padding: 30px 0 36px;
        text-align: center;
        color: var(--muted);
      }

      .footer strong {
        color: var(--primary-dark);
      }

      @media (max-width: 980px) {
        .hero-grid,
        .about-grid,
        .skills-grid,
        .education-grid,
        .projects-grid,
        .contact-grid,
        .hero-stats {
          grid-template-columns: 1fr;
        }

        .hero-photo-box {
          order: -1;
        }

        .profile-photo {
          width: 220px;
          height: 220px;
        }
      }

      @media (max-width: 640px) {
        .nav-inner {
          flex-direction: column;
          align-items: flex-start;
        }

        .nav-links {
          gap: 14px;
        }

        .hero-content,
        .hero-photo-box {
          padding: 24px 18px;
        }

        .profile-photo {
          width: 190px;
          height: 190px;
        }

        .hero h1 {
          font-size: 2.3rem;
        }
      }
    </style>
  </head>

  <body>
    <header class="navbar">
      <div class="nav-inner">
        <a href="#top" class="brand">Rym Hallioui</a>

        <nav class="nav-links">
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#education">Education</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container">
          <div class="hero-grid">
            <div class="hero-content">
              <div class="availability">
                <span class="availability-dot"></span>
                Available for internships and learning opportunities
              </div>

              <h1>Rym Hallioui</h1>

              <p class="hero-role">Software Engineering Student</p>

              <p class="hero-school">Student at ESISA</p>

              <p class="hero-description">
                I am a software engineering student at ESISA, passionate about web
                development, elegant interfaces, and modern digital experiences. I
                enjoy learning by building practical projects and strengthening my
                technical foundations step by step.
              </p>

              <div class="hero-actions">
                <a href="#projects" class="btn btn-primary">View Projects</a>
                <a href="/CV-RYM-HALLIOUI.pdf" class="btn btn-secondary" download>Download Resume</a>
                <a href="#contact" class="btn btn-secondary">Contact Me</a>
              </div>

              <div class="hero-socials">
                <a
                  href="https://www.linkedin.com/in/rym-hallioui-0778873b5/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-pill"
                >
                  LinkedIn
                </a>

                <a
                  href="https://github.com/rhallioui-a11y"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-pill"
                >
                  GitHub
                </a>
              </div>

              <div class="hero-stats">
                <div class="stat-card">
                  <div class="stat-value">ESISA</div>
                  <div class="stat-label">Current school</div>
                </div>

                <div class="stat-card">
                  <div class="stat-value">2+</div>
                  <div class="stat-label">Featured projects</div>
                </div>

                <div class="stat-card">
                  <div class="stat-value">Bac</div>
                  <div class="stat-label">Physical Sciences</div>
                </div>
              </div>
            </div>

            <div class="hero-photo-box">
              <img src="/rym-profile.png" alt="Rym Hallioui" class="profile-photo" />
              <p class="photo-caption">
                Software Engineering Student building creative and professional web experiences.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="about">
        <div class="container">
          <h2 class="section-title">About Me</h2>
      
          <div class="about-grid">
            <article class="about-card">
              <div class="about-number">01</div>
              <p>
                I am currently studying software engineering at ESISA. I am especially
                interested in web development, interface design, and the process of
                turning ideas into useful digital projects.
              </p>
            </article>

            <article class="about-card">
              <div class="about-number">02</div>
              <p>
                I enjoy learning new technologies, improving my coding skills, and
                creating clean, responsive, and user-friendly websites that combine
                structure, creativity, and clarity.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="skills">
        <div class="container">
          <h2 class="section-title">Skills</h2>
          <p class="section-subtitle">
            A concise overview of the tools, technologies, and qualities that define
            my current learning journey.
          </p>

          <div class="skills-grid">
            <article class="skill-card">
              <h3>Frontend Development</h3>
              <p>
                Building clear and responsive user interfaces with modern web
                fundamentals.
              </p>
              <div class="tags">
                <span class="tag">HTML</span>
                <span class="tag">CSS</span>
                <span class="tag">JavaScript</span>
                <span class="tag">Responsive Design</span>
              </div>
            </article>

            <article class="skill-card">
              <h3>Tools & Workflow</h3>
              <p>
                Using practical tools for coding, version control, and deployment.
              </p>
              <div class="tags">
                <span class="tag">Git</span>
                <span class="tag">GitHub</span>
                <span class="tag">VS Code</span>
                <span class="tag">Astro</span>
                <span class="tag">Vercel</span>
              </div>
            </article>

            <article class="skill-card">
              <h3>Soft Skills</h3>
              <p>
                Personal strengths that support progress, autonomy, and creativity.
              </p>
              <div class="tags">
                <span class="tag">Creativity</span>
                <span class="tag">Curiosity</span>
                <span class="tag">Organization</span>
                <span class="tag">Adaptability</span>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="education">
        <div class="container">
          <h2 class="section-title">Education</h2>
          <p class="section-subtitle">
            A short academic overview that presents both my background and my current studies.
          </p>

          <div class="education-grid">
            <article class="education-card">
              <span class="education-badge">Current</span>
              <h3>Software Engineering Student at ESISA</h3>
              <p>
                Currently studying software engineering at ESISA and developing my
                knowledge in programming, web development, problem solving, and
                digital project creation.
              </p>
            </article>

            <article class="education-card">
              <span class="education-badge">Previous</span>
              <h3>Baccalaureate in Physical Sciences</h3>
              <p>
                Earned a baccalaureate in Physical Sciences, which helped me build
                analytical thinking, rigor, and a strong academic foundation for my
                current studies in engineering.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="projects">
        <div class="container">
          <h2 class="section-title">Projects</h2>
          <p class="section-subtitle">
            Projects are central to a student portfolio because they show motivation,
            curiosity, and practical progress.
          </p>

          <div class="projects-grid">
            <article class="project-card">
              <h3>Student Management System</h3>
              <p>
                A project designed to manage students, courses, and academic
                information with a simple and structured interface.
              </p>
              <div class="tags">
                <span class="tag">HTML</span>
                <span class="tag">CSS</span>
                <span class="tag">JavaScript</span>
              </div>
              <a
                href="https://github.com/rhallioui-a11y"
                target="_blank"
                rel="noopener noreferrer"
                class="project-link"
              >
                View on GitHub →
              </a>
            </article>

            <article class="project-card">
              <h3>Personal Portfolio Website</h3>
              <p>
                A responsive portfolio built with Astro and deployed on Vercel to
                present my profile, my projects, and my professional links in a
                polished and modern way.
              </p>
              <div class="tags">
                <span class="tag">Astro</span>
                <span class="tag">CSS</span>
                <span class="tag">Vercel</span>
              </div>
              <a
                href="https://portfolio-astro-seven-orpin.vercel.app"
                target="_blank"
                rel="noopener noreferrer"
                class="project-link"
              >
                Live Portfolio →
              </a>
            </article>
          </div>
        </div>
      </section>

      <section id="contact">
        <div class="container">
          <h2 class="section-title">Contact</h2>
          <p class="section-subtitle">
            Feel free to connect with me and explore my work through my professional profiles.
          </p>

          <div class="contact-grid">
            <article class="contact-card">
              <h3>LinkedIn</h3>
              <p>
                Follow my academic and professional journey on LinkedIn.
              </p>
              <a
                href="https://www.linkedin.com/in/rym-hallioui-0778873b5/"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-link"
              >
                Visit LinkedIn profile
              </a>
            </article>

            <article class="contact-card">
              <h3>GitHub</h3>
              <p>
                Explore my code, repositories, and future technical projects.
              </p>
              <a
                href="https://github.com/rhallioui-a11y"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-link"
              >
                Visit GitHub profile
              </a>
            </article>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          <strong>Rym Hallioui</strong> — Built with Astro and deployed on Vercel.
        </p>
      </div>
    </footer>
  </body>
</html>
